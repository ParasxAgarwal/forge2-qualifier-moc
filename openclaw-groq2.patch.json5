{
  models: {
    mode: "merge",
    providers: {
      groq2: {
        baseUrl: "https://api.groq.com/openai/v1",
        apiKey: { source: "env", provider: "default", id: "GROQ_API_KEY_2" },
        models: [{ id: "llama-3.3-70b-versatile", name: "Llama 3.3 70B" }]
      }
    }
  },
  agents: {
    defaults: {
      model: {
        primary: "openrouter/google/gemma-4-26b-a4b-it:free",
        fallbacks: ["groq/llama-3.3-70b-versatile", "groq2/llama-3.3-70b-versatile"]
      }
    }
  }
}