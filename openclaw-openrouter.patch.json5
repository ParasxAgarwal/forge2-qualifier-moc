{
  models: {
    mode: "merge",
    providers: {
      openrouter: {
        baseUrl: "https://openrouter.ai/api/v1",
        apiKey: { source: "env", provider: "default", id: "OPENROUTER_API_KEY" },
        models: [
          { id: "google/gemma-4-26b-a4b-it:free", name: "Gemma 4 26B (Free)" }
        ]
      }
    }
  },
  agents: {
    defaults: {
      model: {
        primary: "openrouter/google/gemma-4-26b-a4b-it:free",
        fallbacks: ["openrouter/openrouter/free"]
      }
    }
  }
}