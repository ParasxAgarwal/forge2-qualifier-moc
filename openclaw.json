{
  "gateway": {
    "mode": "local",
    "auth": {
      "token": "YOUR_GATEWAY_TOKEN_HERE"
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "appToken": { "source": "env", "provider": "default", "id": "SLACK_APP_TOKEN" },
      "botToken": { "source": "env", "provider": "default", "id": "SLACK_BOT_TOKEN" }
    }
  },
  "commands": {
    "ownerAllowFrom": ["slack:YOUR_SLACK_USER_ID"]
  },
  "agents": {
    "defaults": {
      "memorySearch": {
        "enabled": false
      }
    }
  }
}